{
  "workspace": "/absolute/path/to/project",
  "product_doc": "/absolute/path/to/project/task.md",
  "refresh_hours": 5,
  "refresh_minutes": null,
  "refresh_seconds": null,
  "permission_mode": "acceptEdits",
  "effort": "high",
  "success_interval_seconds": 1,
  "idle_interval_seconds": 60,
  "executor_agent": "tns-executor",
  "verifier_agent": "tns-verifier",
  "max_budget_usd": null,
  "git": {
    "enabled": true,
    "default_branch": "master",
    "record_all_branches": false,
    "rollback_on_quota_exhaustion": true,
    "auto_init": true
  },
  "quota": {
    "provider": "none",
    "window_token_budget": null,
    "minimum_remaining": null,
    "enforce_freeze": false,
    "freeze_on_unknown": false,
    "command": ""
  },
  "tmux": {
    "enabled": false,
    "auto_create": true,
    "session_name": "",
    "window_name": "tns",
    "socket_name": ""
  },
  "notifications": {
    "email": {
      "enabled": false,
      "method": "local_mail",
      "from": "notify@example.com",
      "to": [
        "you@example.com"
      ],
      "subject_prefix": "[TNS]",
      "smtp": {
        "host": "smtp.example.com",
        "port": 587,
        "username": "smtp-user",
        "password": "smtp-password",
        "starttls": true,
        "ssl": false
      }
    }
  }
}
