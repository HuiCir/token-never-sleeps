{
  "name": "token-never-sleeps",
  "version": "1.0.2",
  "description": "Pure TypeScript distribution of the TNS external orchestration loop",
  "type": "module",
  "bin": {
    "tns": "dist/index.js"
  },
  "files": [
    ".claude-plugin",
    "agents",
    "dist",
    "skills",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build",
    "smoke": "node dist/index.js help"
  },
  "keywords": [
    "claude",
    "tns",
    "agent-orchestration",
    "long-running-agents",
    "typescript"
  ],
  "homepage": "https://anonir.tech/tns/",
  "license": "MIT",
  "dependencies": {
    "date-fns": "^3.6.0",
    "execa": "^9.5.2",
    "which": "^5.0.0",
    "yargs": "^17.7.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/which": "^3.0.4",
    "@types/yargs": "^17.0.33",
    "typescript": "^5.7.0"
  }
}
